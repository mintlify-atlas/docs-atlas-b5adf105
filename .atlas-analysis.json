    "createJsxRuntime(options: JsxRuntimeOptions) — @tooltify/integration-shared (source-transformers/react)",
    "createReactJsxRuntimeFile(packagesDir, shouldInjectSource?) — @tooltify/integration-shared",
    "tooltify CLI — start | stop | status | logs | reset-password",
    "TooltifyConfig — tooltify.config.json schema",
    "BaseStartOptions / ReactOptions / RspackStartOptions — integration option types"
  ]
