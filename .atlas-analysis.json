  "projectType": "sdk-library",
  "projectName": "Tooltify",
  "projectDescription": "Tooltify is a developer tooling SDK that injects a live in-browser devtools panel into React apps, enabling real-time source-file editing and build tracking via a local server, CLI agent manager, and bundler integrations.",
