  "keyFeatures": [
    "In-browser devtools panel injected into React apps via bundler plugin",
    "Real-time source file editing through a Monaco editor UI",
    "Build tracking that attributes file changes to specific users",
    "CLI agent manager (start, stop, status, logs, reset-password)",
    "WebSocket-based agent that opens source files in the local IDE",
    "Rspack bundler integration via rspackTooltify() plugin",
    "JWT-based authentication with session cookies",
    "Cross-platform IDE open-in-editor support (Linux, macOS, Windows)"
  ],
  "publicApiSurface": [
    "startServer() — @tooltify/core",
    "CLIENT_BUNDLE — @tooltify/core",
